NODE_ENV=production

# SVS API base URL — defaults to https://free.api.solanavibestation.com if unset.
SVS_API_BASE_URL=https://free.api.solanavibestation.com

# SVS API for metadata, mint info, price windows, ranking, and price subscriptions.
# Sent as `Authorization: Bearer ...` from the backend only. Never prefix with VITE_.
SVS_API_KEY=

# Regular SVS RPC for phase 1 enrichment and fallback reads.
SVS_RPC_HTTP_URL=https://basic.rpc.solanavibestation.com/?api_key=
SVS_RPC_WS_URL=wss://basic.rpc.solanavibestation.com/?api_key=

# SVS Geyser gRPC for phase 1 live program streams.
# If your SVS gRPC plan is Discord/IP-whitelist based, you may not need an X token.
SVS_GRPC_ENDPOINT=https://basic.grpc.solanavibestation.com
SVS_GRPC_X_TOKEN=

# gRPC watched programs. The defaults below are the currently-known program IDs
# for PumpSwap, Raydium LaunchLab, Raydium CPMM, and Raydium AMM v4. CLMM and
# Pump.fun are intentionally left blank until you verify the program IDs you
# want to track. Set to empty string to disable an individual program.
WATCH_PUMPSWAP_PROGRAM=pAMMBay6oceH9fJKBRHGP5D4bD4sWpmSwMn52FMfXEA
WATCH_RAYDIUM_LAUNCHLAB_PROGRAM=LanMV9sAd7wArD4vJFi2qDdfnVhFxYSUg6eADduJ3uj
WATCH_RAYDIUM_CPMM_PROGRAM=CPMMoo8L3F4NbTegBCKVNunggL7H1ZpdTHKxQB5qKP1C
WATCH_RAYDIUM_AMM_V4_PROGRAM=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8
WATCH_RAYDIUM_CLMM_PROGRAM=
WATCH_PUMPFUN_PROGRAM=

# Phase 2 only: execution / fast transaction landing.
SVS_STAKED_RPC_URL=
SVS_LIGHTSPEED_URL=
